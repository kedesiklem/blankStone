<Entity name="slimeStone">
    <Base file="mods/blankStone/files/entities/elemental_stone.xml">
        <PhysicsImageShapeComponent
            image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_slime.png"
        ></PhysicsImageShapeComponent>

        <SpriteComponent
            image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_slime.png"
        ></SpriteComponent>

        <ItemComponent
            item_name="$stone_blankstone_slimeStone_name"
            ui_description="$stone_blankstone_slimeStone_desc"
            ui_sprite="mods/blankStone/files/ui_gfx/elemental_stone/stone_slime.png"
        ></ItemComponent>

        <UIInfoComponent
            name="$stone_blankstone_slimeStone_name"
        ></UIInfoComponent>

        <AbilityComponent
            ui_name="$stone_blankstone_slimeStone_name"
        ></AbilityComponent>
    </Base>

    <Base file="mods/blankStone/files/entities/infusable.xml" include_children="1" />

    <!-- VFX -->

    <Base file="mods/blankStone/files/VFX/sweat.xml">
        <ParticleEmitterComponent
            emitted_material_name="slime"
            count_min="4"
            count_max="6"
        ></ParticleEmitterComponent>
    </Base>

    <MagicConvertMaterialComponent
        _tags="enabled_in_world,enabled_in_hand"
        from_material="magic_liquid_unstable_teleportation"
        to_material="magic_liquid_teleportation"
        is_circle="1"
        radius="15"
        kill_when_finished="0"
        loop="1"
    ></MagicConvertMaterialComponent>
    <MagicConvertMaterialComponent
        _tags="enabled_in_world,enabled_in_hand"
        from_material_tag="[fire]"
        to_material="cloud_slime"
        is_circle="1"
        radius="15"
        kill_when_finished="0"
        loop="1"
    ></MagicConvertMaterialComponent>
    <MagicConvertMaterialComponent
        _tags="enabled_in_world,enabled_in_hand"
        from_material_tag="[magic_faster]"
        to_material="fire_blue"
        is_circle="1"
        radius="15"
        kill_when_finished="0"
        loop="1"
    ></MagicConvertMaterialComponent>

    <!-- effect -->

    <Base file="data/entities/misc/perks/projectile_slow_field.xml"></Base>

    <GameEffectComponent
        _tags="enabled_in_hand,enabled_in_inventory"
        effect="NO_SLIME_SLOWDOWN"
        frames="-1"
    ></GameEffectComponent>

    <VariableStorageComponent
        name="blankStoneID"
        value_string="slimeStone"
    ></VariableStorageComponent>

</Entity>