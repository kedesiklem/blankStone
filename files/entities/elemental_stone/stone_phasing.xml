<Entity name="phasingStone">

  <Base file="mods/blankStone/files/entities/elemental_stone.xml">
    <PhysicsImageShapeComponent
      image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_phasing.png"
    ></PhysicsImageShapeComponent>

    <SpriteComponent
      image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_phasing.png"
    ></SpriteComponent>

    <ItemComponent
      item_name="$stone_blankstone_phasingStone_name"
      ui_description="$stone_blankstone_phasingStone_desc"
      ui_sprite="mods/blankStone/files/ui_gfx/elemental_stone/stone_phasing.png"
    ></ItemComponent>

    <UIInfoComponent
      name="$stone_blankstone_phasingStone_name"
    ></UIInfoComponent>

    <AbilityComponent
      ui_name="$stone_blankstone_phasingStone_name"
    ></AbilityComponent>
  </Base>


  <!-- === CUSTOM EFFECT === -->
  <LuaComponent
    _tags="enabled_in_hand"
    script_source_file="mods/blankStone/files/scripts/status_effects/custom_effect_stone.lua"
    execute_every_n_frame="30"
  ></LuaComponent>

  <!-- need to apply no_clip each frame -->
  <LuaComponent
    _tags="enabled_in_hand"
    script_source_file="mods/blankStone/files/scripts/status_effects/custom_effect_apply.lua"
    execute_every_n_frame="1"
  ></LuaComponent>

  <!-- Required -->
  <VariableStorageComponent
    name="custom_id"
    value_string="NO_CLIP"
  ></VariableStorageComponent>
  <!-- ============================== -->


  <!-- VFX -->
  <GameEffectComponent
    _tags="enabled_in_hand,enabled_in_inventory"
    effect="INVISIBILITY"
    frames="-1"
  ></GameEffectComponent>

  <VariableStorageComponent
    name="blankStoneID"
    value_string="phasingStone"
  ></VariableStorageComponent>

</Entity>