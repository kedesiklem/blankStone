<Entity name="forgeStone" tags="indesctructible">
    <Base file="mods/blankStone/files/entities/elemental_stone.xml">

        <!-- physical presence -->

        <PhysicsImageShapeComponent
            image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_forge.png"
        ></PhysicsImageShapeComponent>

        <!-- item -->

        <SpriteComponent
            image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_forge.png"
        ></SpriteComponent>

        <ItemComponent
            item_name="$stone_blankstone_forgeStone_name"
            ui_description="$stone_blankstone_forgeStone_desc"
            ui_sprite="mods/blankStone/files/ui_gfx/elemental_stone/stone_forge.png"
        ></ItemComponent>

        <UIInfoComponent
            name="$stone_blankstone_forgeStone_name"
        ></UIInfoComponent>

        <AbilityComponent
            ui_name="$stone_blankstone_forgeStone_name"
        ></AbilityComponent>

        <VariableStorageComponent
            name="purifyInto"
            value_string="mods/blankStone/files/entities/quintessence_stone.xml"
        ></VariableStorageComponent>
    </Base>

    <!-- VFX — Ray #1 -->
    <Base file="mods/blankStone/files/VFX/ray.xml">
        <SpriteParticleEmitterComponent
            color.r="0.4545" color.g="0.2018" color.b="0.4807" color.a="0.11"
            additive="1" emissive="1"
        ></SpriteParticleEmitterComponent>
    </Base>

    <!-- LuaComponent -->
    <LuaComponent
        _tags="enabled_in_hand,enabled_in_world"
        execute_every_n_frame="36"
        script_source_file="data/scripts/buildings/forge_item_check.lua"
    ></LuaComponent>


    <VariableStorageComponent
        name="blankStoneID"
        value_string="forgeStone"
    ></VariableStorageComponent>

</Entity>