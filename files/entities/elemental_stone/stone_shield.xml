<Entity name="shieldStone" tags="energy_shield">
    <Base file="mods/blankStone/files/entities/elemental_stone.xml">

        <!-- physical presence -->

        <PhysicsImageShapeComponent
            image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_shield.png"
        ></PhysicsImageShapeComponent>

        <!-- item -->

        <SpriteComponent
            image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_shield.png"
        ></SpriteComponent>

        <ItemComponent
            item_name="$stone_blankstone_shieldStone_name"
            ui_description="$stone_blankstone_shieldStone_desc"
            ui_sprite="mods/blankStone/files/ui_gfx/elemental_stone/stone_shield.png"
        ></ItemComponent>

        <UIInfoComponent
            name="$stone_blankstone_shieldStone_name"
        ></UIInfoComponent>

        <AbilityComponent
            ui_name="$stone_blankstone_shieldStone_name"
        ></AbilityComponent>
    </Base>

    <!-- VFX Halo #1 -->
    <Base file="mods/blankStone/files/VFX/halo.xml">
        <SpriteParticleEmitterComponent
            color.r="0.3757" color.g="0.9069" color.b="1" color.a="0.25"
            color_change.r="0" color_change.g="0" color_change.b="0" color_change.a="-1.5"
            additive="1"
            emissive="1"
        ></SpriteParticleEmitterComponent>
    </Base>

    <!-- VFX Sweat #1 -->
    <Base file="mods/blankStone/files/VFX/sweat.xml">
        <ParticleEmitterComponent
            emitted_material_name="plasma_fading"
            count_min="3"
            count_max="5"
        ></ParticleEmitterComponent>
    </Base>


    <VariableStorageComponent
        name="blankStoneID"
        value_string="shieldStone"
    ></VariableStorageComponent>


    <!-- SHIELD -->
    <Entity>
        <Base file="mods/blankStone/files/entities/misc/shield.xml"></Base>
    </Entity>

</Entity>