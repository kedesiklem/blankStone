<Entity name="bonesStone">

  <Base file="mods/blankStone/files/entities/elemental_stone.xml">
    <PhysicsImageShapeComponent
      image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_bones.png"
    ></PhysicsImageShapeComponent>

    <SpriteComponent
      image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_bones.png"
    ></SpriteComponent>

    <ItemComponent
      item_name="$stone_blankstone_bonesStone_name"
      ui_description="$stone_blankstone_bonesStone_desc"
      ui_sprite="mods/blankStone/files/ui_gfx/elemental_stone/stone_bones.png"
    ></ItemComponent>

    <UIInfoComponent
      name="$stone_blankstone_bonesStone_name"
    ></UIInfoComponent>

    <AbilityComponent
      ui_name="$stone_blankstone_bonesStone_name"
    ></AbilityComponent>
  </Base>

  <!-- VFX -->

  <!-- effect -->

  <!-- === CUSTOM EFFECT === -->
  <LuaComponent
    _tags="enabled_in_hand,enabled_in_inventory"
    script_source_file="mods/blankStone/files/scripts/status_effects/custom_effect_stone.lua"
    execute_every_n_frame="30"
  ></LuaComponent>

  <!-- Required -->
  <VariableStorageComponent
    name="custom_id"
    value_string="PEACE_WITH_GODS"
  ></VariableStorageComponent>
  <!-- ============================== -->


  <VariableStorageComponent
    name="blankStoneID"
    value_string="bonesStone"
  ></VariableStorageComponent>

</Entity>