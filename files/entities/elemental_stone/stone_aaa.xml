<!-- Can be reforged -->
<Entity name="aaaStone" tags="forgeable">

  <Base file="mods/blankStone/files/entities/elemental_stone.xml">
    <PhysicsImageShapeComponent
      image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_aaa.png"
    ></PhysicsImageShapeComponent>

    <SpriteComponent
      image_file="mods/blankStone/files/items_gfx/elemental_stone/stone_aaa.png"
    ></SpriteComponent>

    <ItemComponent
      item_name="$stone_blankstone_aaaStone_name"
      ui_description="$stone_blankstone_aaaStone_desc"
      ui_sprite="mods/blankStone/files/ui_gfx/elemental_stone/stone_aaa.png"
    ></ItemComponent>

    <UIInfoComponent
      name="$stone_blankstone_aaaStone_name"
    ></UIInfoComponent>

    <AbilityComponent
      ui_name="$stone_blankstone_aaaStone_name"
    ></AbilityComponent>

    <!-- Set the stone it purify into (default blankStone) -->
    <VariableStorageComponent
      name="purifyInto"
      value_string="mods/blankStone/files/entities/blank_stone.xml"
    ></VariableStorageComponent>
  </Base>

  <!-- Can be infused -->
  <Base file="mods/blankStone/files/entities/infusable.xml" include_children="1" />

  <!-- effect -->
  <GameEffectComponent
    _tags="enabled_in_hand,enabled_in_inventory"
    effect="MOVEMENT_FASTER"
    frames="-1"
  ></GameEffectComponent>

  <VariableStorageComponent
    name="blankStoneID"
    value_string="aaaStone"
  ></VariableStorageComponent>

</Entity>